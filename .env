APP_ENV=production
# FIX: set APP_ORIGIN to your actual production domain, not localhost
# Example: APP_ORIGIN=https://agroinsight.example.com
APP_ORIGIN=http://localhost
STRICT_AUTH=true

# FIX: never use root with empty password in production.
# Create a dedicated DB user: CREATE USER 'agro'@'localhost' IDENTIFIED BY 'strong_password';
# GRANT ALL ON agroinsight.* TO 'agro'@'localhost';
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=agroinsight

# Get your free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here
OPENWEATHER_BASE=https://api.openweathermap.org/data/2.5

# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

PYTHON_EXEC=python
ML_TIMEOUT_SECONDS=25

RATE_LIMIT_AUTH=10
RATE_LIMIT_CHAT=20
RATE_LIMIT_WEATHER=60
RATE_LIMIT_WINDOW_SECONDS=60

# Set to false and fill in Twilio credentials to send real SMS
SMS_MOCK_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
